{
  "name": "snipstack-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx apps/api/src/server.ts",
    "build": "npm run build -w apps/web && npm run build -w apps/api",
    "start": "node apps/api/dist/server.js",
    "prisma:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=apps/api/prisma/schema.prisma",
    "lint": "tsc -p apps/web/tsconfig.json && tsc -p apps/api/tsconfig.json"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@prisma/client": "^6.2.1",
    "@tanstack/react-query": "^5.100.10",
    "@types/lodash": "^4.17.24",
    "@uiw/react-codemirror": "^4.25.9",
    "axios": "^1.16.1",
    "bcrypt": "^5.1.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.18.1",
    "react-router-dom": "^6.30.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.25.0",
    "prisma": "^6.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
